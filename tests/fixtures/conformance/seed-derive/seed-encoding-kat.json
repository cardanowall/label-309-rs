      "seed_hex": "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
      "encoded": "L309-SEED-1LLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLLSAHLZWA",
      "encoded_lowercase": "l309-seed-1lllllllllllllllllllllllllllllllllllllllllllllllllllsahlzwa"
    },
    {
      "name": "seed-deadbeef",
      "seed_hex": "deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef",
      "encoded": "L309-SEED-1M6KMAM774KLWLH4DHMHAATD7AL02M0H0M6KMAM774KLWLH4DHMHSZSZA7U",
